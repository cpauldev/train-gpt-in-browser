{
  "name": "train-gpt-in-browser",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome lint --config-path ./biome.json --css-parse-tailwind-directives=true ./src ./index.html ./package.json ./tsconfig.json ./tsconfig.node.json ./components.json ./vite.config.ts",
    "lint:unused": "bun run lint:unused:project",
    "lint:unused:project": "knip --production --include files,dependencies,unlisted",
    "lint:unused:exports": "knip --include exports,types",
    "lint:unused:fix": "knip --production --include exports --fix",
    "format": "biome format --config-path ./biome.json --css-parse-tailwind-directives=true --write ./src ./index.html ./package.json ./tsconfig.json ./tsconfig.node.json ./components.json ./vite.config.ts",
    "check": "biome check --config-path ./biome.json --css-parse-tailwind-directives=true ./src ./index.html ./package.json ./tsconfig.json ./tsconfig.node.json ./components.json ./vite.config.ts",
    "check:write": "biome check --config-path ./biome.json --css-parse-tailwind-directives=true --write ./src ./index.html ./package.json ./tsconfig.json ./tsconfig.node.json ./components.json ./vite.config.ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.17",
    "@fontsource-variable/manrope": "^5.2.8",
    "@noble/hashes": "^1.8.0",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-backend-webgpu": "^4.22.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "liveline": "^0.0.6",
    "long": "^5.3.2",
    "lucide-react": "^0.577.0",
    "onnx-proto": "^8.0.1",
    "react": "^19.1.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.0",
    "fake-indexeddb": "^6.2.2",
    "jsdom": "^26.1.0",
    "knip": "^5.63.1",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
